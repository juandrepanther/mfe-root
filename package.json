{
  "name": "dashboard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "env NODE_OPTIONS='--localstorage-file=.next/localstorage.json' next dev --port 3000",
    "build": "env NODE_OPTIONS='--localstorage-file=.next/localstorage.json' next build",
    "start": "env NODE_OPTIONS='--localstorage-file=.next/localstorage.json' next start",
    "lint": "env NODE_OPTIONS='--localstorage-file=.next/localstorage.json' next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:ui": "vitest"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.0.2",
    "next": "15.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^9.25.0",
    "eslint-config-next": "15.3.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "jsdom": "^29.1.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
